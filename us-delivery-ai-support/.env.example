# LLM configuration
# This project uses an OpenAI-compatible client, so the OPENAI_* names work for
# any compatible provider (OpenAI, Groq, etc.). Copy this file to .env and fill
# in your real key there — never put real secrets in this example file.
#
# For Groq:
#   OPENAI_API_KEY=gsk_your_groq_key_here
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_MODEL=llama-3.3-70b-versatile
# For OpenAI:
#   OPENAI_API_KEY=sk_your_openai_key_here
#   OPENAI_BASE_URL=            (leave empty to use OpenAI's default endpoint)
#   OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0
LLM_SEED=42

# App configuration
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Dataset paths
DATA_DIR=./data
TICKETS_FILE=./data/tickets.json
ACCOUNTS_FILE=./data/accounts.json
KB_DIR=./knowledge-base

# Prompt configuration
PROMPT_DIR=./prompts
TRIAGE_PROMPT_VERSION=triage_v1
ACCOUNT_PROMPT_VERSION=account_summary_v1
JUDGE_PROMPT_VERSION=judge_v1

# Retrieval configuration
TOP_K_KB_DOCS=3

# Evaluation configuration
EVAL_REPORT_JSON=./eval_report.json
EVAL_REPORT_MD=./eval_report.md

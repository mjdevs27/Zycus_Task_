# Streamlit Community Cloud secrets template.
#
# Copy these keys into the "Secrets" box of your Streamlit Cloud app
# (Manage app -> Settings -> Secrets) and paste your REAL values there.
#
# Do NOT commit a real secrets.toml — .streamlit/secrets.toml is gitignored.
# These keys are bridged into the environment by ui/streamlit_app.py so the
# same app.config Settings work locally (.env) and when deployed (st.secrets).

OPENAI_API_KEY = "your_rotated_groq_or_openai_key_here"
OPENAI_BASE_URL = "https://api.groq.com/openai/v1"
OPENAI_MODEL = "llama-3.3-70b-versatile"
LLM_TEMPERATURE = "0"
LLM_SEED = "42"
